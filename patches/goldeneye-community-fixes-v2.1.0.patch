+#include <array>
 #include <atomic>
+#include <chrono>
 #include <cstdint>
 #include <cstring>
 
@@ -899,6 +901,12 @@ constexpr uint32_t GE_SETTINGS_PTR  = 0x83088228u;  // -> settings struct pointe
 constexpr uint32_t GE_SETTINGS_BITS = 0x298u;       // bitflags offset in struct
